set -g mode-style "fg=${thm_selection_fg},bg=${thm_selection_bg}"
set -g message-style "fg=${thm_fg},bg=default"
set -g message-command-style "fg=${thm_fg},bg=default"
set -g pane-border-style "fg=${thm_inactive_pane_bg}"
set -g pane-active-border-style "fg=${thm_active_pane_bg}"
set -g status "on"
set -g status-justify "left"
set -g status-style "fg=${thm_fg},bg=default"
set -g status-left-length "100"
set -g status-right-length "100"
set -g status-left-style NONE
set -g status-right-style NONE
set -g status-left "#[fg=${thm_bg},bg=#{?client_prefix,${thm_command_mode_bg},${thm_active_pane_bg}},bold] 󰏗 #S #[fg=#{?client_prefix,${thm_command_mode_bg},${thm_active_pane_bg}},bg=default,nobold] #[fg=${thm_selection_fg},nobold]#{agent_session_dots} "
set -g status-right "#[fg=${thm_active_pane_bg},bg=default]#[fg=${thm_bg},bg=${thm_active_pane_bg},bold]󰚯 #W "
set -wg window-status-activity-style "none"
set -wg window-status-separator " "
set -wg window-status-style "none,fg=${thm_selection_bg},bg=default"
set -wg window-status-format "#I"
set -wg window-status-bell-style "fg=${thm_command_mode_bg},bg=default,bold"
set -wg window-status-current-format "#[fg=${thm_active_pane_bg},bg=default,bold]#I"
