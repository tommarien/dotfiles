#!/usr/bin/env bash

get_color() {
    local query="$1"
    local label="$2"
    local resp old
    exec 3<>/dev/tty
    old=$(stty -g <&3)
    stty raw -echo min 0 time 2 <&3
    printf '%s' "$query" >&3
    resp=$(dd bs=100 count=1 2>/dev/null <&3)
    stty "$old" <&3
    exec 3>&-
    if [[ "$resp" =~ rgb:([0-9a-fA-F]{2})[0-9a-fA-F]*/([0-9a-fA-F]{2})[0-9a-fA-F]*/([0-9a-fA-F]{2})[0-9a-fA-F]* ]]; then
        printf "%-28s #%s%s%s\n" "$label" "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}"
    fi
}

get_color $'\e]10;?\e\\' "foreground"
get_color $'\e]11;?\e\\' "background"
get_color $'\e]12;?\e\\' "cursor"
for i in $(seq 0 15); do
    get_color $'\e]'"4;$i;?"$'\e\\' "color$i"
done
